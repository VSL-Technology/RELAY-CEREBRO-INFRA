# ─────────────────────────────────────────────────
# RELAY-CEREBRO-INFRA — variáveis de ambiente
# Gere chaves com: openssl rand -hex 32
# ─────────────────────────────────────────────────

# ⚠️  VARIÁVEIS OBRIGATÓRIAS (boot falha sem estas):
# ─────────────────────────────────────────────────

# Environment: development, staging, production
# ⚠️  REQUIRED
NODE_ENV=production

# ⚠️  REQUIRED - Segredo HMAC para assinar/verificar requisições entre dashboard e relay
# Gere com: openssl rand -hex 32
RELAY_API_SECRET=

# ⚠️  REQUIRED - Chave privada do WireGuard no relay
# Gere com: wg genkey
WG_PRIVATE_KEY=

# ⚠️  REQUIRED - Interface de WireGuard (ex: wg0)
WG_INTERFACE=wg0

# ⚠️  REQUIRED - Banco de dados PostgreSQL
# Formato: postgresql://user:pass@host:port/database
DATABASE_URL=postgresql://user:pass@host:5432/db?options=-c%20search_path%3Drelay

# ─── VARIÁVEIS OPCIONAIS ───────────────────────

# Auth principal do relay (Bearer token)
RELAY_TOKEN=

# Chave mestra para criptografia de segredos em repouso (AES-256-GCM)
# Gere com: openssl rand -hex 32
RELAY_MASTER_KEY=

# ─── Redis ─────────────────────────────────────
# URL do Redis: redis://redis:6379 (docker-compose) ou redis://127.0.0.1:6379 (host network)
# CRÍTICO para deploy com múltiplas instâncias:
# sem redis, jobs podem executar duplicado entre instâncias
REDIS_URL=redis://redis:6379
RELAY_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Se true, falha no boot quando Redis não está disponível
REDIS_REQUIRED=false

# ─── MikroTik ──────────────────────────────────
# JSON array com nós MikroTik: [{"id":"ID","host":"IP","user":"u","pass":"p","port":8728}]
MIKROTIK_NODES=[]

# ─── Circuit Breaker ───────────────────────────
# Número de falhas consecutivas para abrir o circuito
CB_FAILURE_THRESHOLD=5
# Tempo de recuperação em ms antes de tentar novamente (half-open)
CB_RECOVERY_TIMEOUT_MS=60000

# ─── HMAC ──────────────────────────────────────
# Janela de tolerância de timestamp em ms (padrão 300s = 5 min)
HMAC_WINDOW_MS=300000
# Token para o scraper do Prometheus/Grafana acessar /metrics
METRICS_TOKEN="gere-com-openssl-rand-hex-32"
# URL de webhook para alertas (Slack, Discord, PagerDuty, etc.)
# Deixe vazio para desabilitar alertas — o sistema funciona sem isso
ALERT_WEBHOOK_URL=""

# ─── Rate limit ────────────────────────────────
RELAY_RATE_WINDOW_MS=60000
RELAY_RATE_LIMIT=60
RATE_LIMIT_PER_ROUTER=60

# ─── WireGuard ─────────────────────────────────
# CRÍTICO para deploy — chave privada do WireGuard no relay
# Gere com: wg genkey
WG_PRIVATE_KEY=
WG_INTERFACE=wg0
WG_VPS_PUBLIC_KEY=
WG_VPS_ENDPOINT=

# ─── Control plane ─────────────────────────────
CONTROL_PLANE_MODE=B
CONTROL_PLANE_FALLBACK_JSON=true
CONTROL_PLANE_WRITE_DB=true
JOB_RUNNER_ENABLED=false

# ─── Sessões ───────────────────────────────────
SESSION_PUBLIC=false
SESSION_MONITOR_CONCURRENCY=10
SESSION_CLEANER_CONCURRENCY=20

PORT=3000
